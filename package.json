{
  "name": "@yebichu/zustand-socketio",
  "version": "0.1.0",
  "description": "Zero-provider, batteries-included Socket.IO integration for Zustand",
  "author": "yebichu",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./middleware": {
      "types": "./dist/middleware.d.ts",
      "import": "./dist/middleware.js",
      "require": "./dist/middleware.cjs"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build && npm run typecheck"
  },
  "peerDependencies": {
    "socket.io-client": ">=4",
    "zustand": ">=4"
  },
  "dependencies": {
    "micromatch": "^4.0.8"
  },
  "devDependencies": {
    "@types/micromatch": "^4.0.9",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "socket.io-client": "^4.8.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "zustand": "^4.5.5"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": ["zustand", "socket.io", "websocket", "real-time", "react", "state-management"]
}
